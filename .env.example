# .env.example - copy to .env and edit values
# Database configuration (choose sqlite for development or postgresql for production)
DB_TYPE=sqlite               # or postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=servicedesk
DB_USER=servicedesk
DB_PASSWORD=your-db-password

# Secret key - generate a secure 64‑byte hex string
# python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=replace-with-generated-hex

# Company name displayed in the UI
COMPANY_NAME=YourCompany

# Flask environment (development or production)
FLASK_ENV=development
FLASK_DEBUG=true
