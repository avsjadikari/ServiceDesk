# .env.example — copy to .env and edit values for your environment.
# Generate a strong SECRET_KEY with:
#   python -c "import secrets; print(secrets.token_hex(64))"

# --- Flask ---
FLASK_CONFIG=development           # development | testing | production
FLASK_DEBUG=false                  # must be false in production
SECRET_KEY=replace-me-with-a-64-byte-hex-secret
COMPANY_NAME=ServiceDesk

# --- Database ---
# Use sqlite for local dev, postgresql for production.
DB_TYPE=sqlite                     # sqlite | postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=servicedesk
DB_USER=servicedesk
# DB_PASSWORD is REQUIRED when DB_TYPE=postgresql.
# The application will refuse to start without it.
DB_PASSWORD=

# --- Redis (used by Celery / Flask-Limiter in production) ---
REDIS_URL=redis://localhost:6379/0

# --- Mail (SMTP) ---
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Uploads ---
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH_MB=16

# --- Security headers (production) ---
# Set to false only when TLS is terminated upstream and you want to avoid
# the in-app redirect (e.g. behind a load balancer on a private network).
TALISMAN_FORCE_HTTPS=true

# --- Gunicorn (when running in Docker / behind a process manager) ---
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
GUNICORN_LOG_LEVEL=info
