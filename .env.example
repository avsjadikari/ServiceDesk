# ServiceDesk Environment Configuration
# Copy this file to .env and configure

# ===================
# Database Configuration
# ===================
DB_TYPE=postgresql          # sqlite or postgresql
DB_HOST=localhost          # Database host
DB_PORT=5432               # Database port
DB_NAME=servicedesk         # Database name
DB_USER=servicedesk         # Database username
DB_PASSWORD=your_password   # Database password
DB_SSL_MODE=prefer         # require, verify-full, prefer, disable

# ===================
# Security
# ===================
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=your-generated-secret-key

# ===================
# Company
# ===================
COMPANY_NAME=YourCompany

# ===================
# Flask Configuration
# ===================
FLASK_ENV=development       # development or production
FLASK_DEBUG=true            # true or false

# ===================
# Email / SMTP Configuration
# ===================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@yourdomain.com

# ===================
# Backup Configuration
# ===================
BACKUP_DIR=backups          # Directory to store backups
